    },
    {
      "id": "board-settings-dialog",
      "label": "Board settings dialog",
      "location": "board.dialogs.settings",
      "type": "dialog"
    },
    {
      "id": "columns-settings-section",
      "label": "Columns settings section",
      "location": "board.dialogs.settings.columns",
      "type": "form-section"
    },
    {
      "id": "category-settings-toggle",
      "label": "Draft category toggle",
      "location": "board.dialogs.settings.categories.toggle",
